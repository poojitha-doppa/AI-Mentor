# ═══════════════════════════════════════════════════════════
# PROJECT EXPO - Environment Configuration
# ═══════════════════════════════════════════════════════════

# SUPABASE - Used by all modules (Required)
VITE_SUPABASE_URL=your_supabase_url_here
VITE_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# ═══════════════════════════════════════════════════════════
# BACKEND CONFIGURATION
# ═══════════════════════════════════════════════════════════

# Main App Backend
BACKEND_URL=http://localhost:3000
API_PORT=3000
NODE_ENV=development

# Course Service Backend
COURSE_SERVICE_PORT=3001
COURSE_SERVICE_URL=http://localhost:3001

# Database
DATABASE_URL=your_database_url_here

# ═══════════════════════════════════════════════════════════
# FRONTEND PORTS
# ═══════════════════════════════════════════════════════════

VITE_LANDING_PAGE_PORT=4173
VITE_COURSE_GENERATION_PORT=3005
VITE_ROADMAP_PORT=5173
VITE_TEST_GENERATION_PORT=3000

# ═══════════════════════════════════════════════════════════
# AI/ML APIs
# ═══════════════════════════════════════════════════════════

VITE_GEMINI_API_KEY=your_gemini_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
GOOGLE_API_KEY=your_google_api_key_here

# ═══════════════════════════════════════════════════════════
# FEATURE FLAGS
# ═══════════════════════════════════════════════════════════

ENABLE_COURSE_GENERATION=true
ENABLE_ROADMAP=true
ENABLE_TEST_GENERATION=true
ENABLE_AUTH=true
ENABLE_ANALYTICS=false

# ═══════════════════════════════════════════════════════════
# LOGGING & DEBUGGING
# ═══════════════════════════════════════════════════════════

DEBUG=false
LOG_LEVEL=info
VITE_DEBUG=false

# ═══════════════════════════════════════════════════════════
# CORS & SECURITY
# ═══════════════════════════════════════════════════════════

CORS_ORIGIN=http://localhost:*
JWT_SECRET=your_jwt_secret_here_min_32_chars
SESSION_SECRET=your_session_secret_here

# ═══════════════════════════════════════════════════════════
# EXTERNAL INTEGRATIONS
# ═══════════════════════════════════════════════════════════

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password_here

# ═══════════════════════════════════════════════════════════
# DEPLOYMENT
# ═══════════════════════════════════════════════════════════

VERCEL_URL=
NEXT_PUBLIC_SITE_URL=http://localhost:3005
